DB_HOST=postgres
DB_PORT=5432
DB_USER=ocr_user
DB_PASSWORD=ocr_secure_password
DB_NAME=ocr_service
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET_KEY=change-me-in-production-very-long-secret
ENCRYPTION_KEY=32-byte-encryption-key-here!!

RATE_LIMIT_PER_MINUTE=60
OCR_LANGUAGES=uzb+rus+eng
MAX_FILE_SIZE=10485760

LOG_LEVEL=INFO
LOG_FORMAT=json

# VLM — Qwen (Alibaba Cloud Plan — с Visual Understanding)
# Поддерживаемые модели: qwen3.5-plus, kimi-k2.5
VLM_PROVIDER=qwen
QWEN_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen3.5-plus
QWEN_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# VLM — Google Gemini Vision API (резерв)
# Получи ключ: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-1.5-flash

# VLM — Groq (резерв)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.2-11b-vision-preview
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# VLM — Alibaba Qwen-VL (резерв)
# QWEN_API_KEY=sk-...
# QWEN_MODEL=qwen-vl-max-latest
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
